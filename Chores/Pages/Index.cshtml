@page
@model IndexModel
@{
    ViewData["Title"] = "Chore Dashboard";
}

<style>
    .chore-list { list-style: none; padding: 0; margin: 0; }
    .chore-row {
        display: flex; align-items: center; justify-content: space-between; gap: 8px;
        padding: 14px 16px; margin-bottom: 8px;
        background: var(--bs-body-bg); border: 1px solid var(--bs-border-color); border-radius: 10px;
        box-shadow: 0 1px 4px rgba(0,0,0,.06);
        text-decoration: none; color: inherit;
        transition: background .15s;
    }
    .chore-row:hover { background: var(--bs-tertiary-bg); }
    .chore-labels { display:flex; gap:4px; flex-wrap:wrap; }
    .label-pill { padding:2px 8px; border-radius:10px; font-size:0.75rem; color:#fff; font-weight:500; }
</style>

<h2 class="mb-3">My Household Chores</h2>

@if (Model.AllLabels.Any())
{
    <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
        <a href="/" class="badge @(Model.ActiveLabelId == null ? "border border-dark text-dark" : "bg-secondary text-white")"
           style="text-decoration:none; padding:6px 12px;">All</a>
        @foreach (var label in Model.AllLabels)
        {
            var isActive = Model.ActiveLabelId == label.Id;
            <a href="?labelId=@label.Id"
               class="badge"
               style="background-color:@label.Color; opacity:@(isActive ? "1" : "0.6"); text-decoration:none; padding:6px 12px; color:#fff;">
                @label.Name
            </a>
        }
    </div>
}

@if (!Model.ChoreStatuses.Any())
{
    <p class="text-muted">No chores yet. <a asp-page="/Chores/Index">Add some chores</a> to get started.</p>
}
else
{
    <ul class="chore-list">
        @foreach (var cs in Model.ChoreStatuses)
        {
            <li>
                <a class="chore-row" href="/Chores/Complete?id=@cs.Chore.Id">
                    <span class="chore-name">@cs.Chore.Name</span>
                    <span class="chore-labels">
                        @foreach (var label in cs.Chore.Labels)
                        {
                            <span class="label-pill" style="background-color:@label.Color;">@label.Name</span>
                        }
                    </span>
                    @{
                        string badgeClass, badgeText;
                        if (cs.Adherence.Status == AdherenceStatus.OnTime)
                        {
                            badgeClass = "text-bg-success";
                            badgeText = "On time";
                        }
                        else if (cs.Adherence.Status == AdherenceStatus.DueToday)
                        {
                            badgeClass = "text-bg-warning";
                            badgeText = "Due today";
                        }
                        else
                        {
                            badgeClass = "text-bg-danger";
                            badgeText = cs.Adherence.DaysOverdue == int.MaxValue
                                ? "Never done"
                                : $"{cs.Adherence.DaysOverdue} days overdue";
                        }
                    }
                    <span class="badge @badgeClass">@badgeText</span>
                </a>
            </li>
        }
    </ul>
}
