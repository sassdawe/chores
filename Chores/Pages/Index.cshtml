@page
@model IndexModel
@{
    ViewData["Title"] = "Chore Dashboard";
}

<style>
    .chore-list { list-style: none; padding: 0; margin: 0; }
    .chore-row {
        display: grid; grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr); align-items: center; gap: 8px;
        padding: 14px 16px; margin-bottom: 8px;
        background: var(--bs-body-bg); border: 1px solid var(--bs-border-color); border-radius: 10px;
        box-shadow: 0 1px 4px rgba(0,0,0,.06);
        text-decoration: none; color: inherit;
        transition: background .15s;
    }
    .chore-row:hover { background: var(--bs-tertiary-bg); }
    .chore-name { min-width: 0; }
    .chore-labels { display:flex; gap:4px; flex-wrap:wrap; }
    .chore-row .chore-labels { justify-self: center; }
    .chore-row > .badge { justify-self: end; }
    .label-pill { padding:2px 8px; border-radius:10px; font-size:0.75rem; color:#fff; font-weight:500; }
    .dashboard-filter-bar { display:flex; align-items:center; margin-bottom:1rem; }
    .dashboard-space-toggle { display:inline-flex; align-items:center; gap:.5rem; max-width:min(100%, 28rem); }
    .dashboard-space-summary { display:inline-block; max-width:18rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .dashboard-space-menu { min-width:min(22rem, calc(100vw - 2rem)); }
    .dashboard-space-options { display:grid; gap:.5rem; max-height:16rem; overflow:auto; }
    .dashboard-space-actions { display:flex; justify-content:flex-end; gap:.5rem; }
</style>

@if (Model.Spaces.Count > 1)
{
    <form method="get" class="dashboard-filter-bar">
        @if (Model.ActiveLabelId.HasValue)
        {
            <input type="hidden" name="labelId" value="@Model.ActiveLabelId" />
        }
        <div class="dropdown" data-bs-auto-close="outside">
            <button class="btn btn-outline-secondary dropdown-toggle dashboard-space-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <span class="text-body-secondary">Spaces:</span>
                <span class="dashboard-space-summary fw-semibold">@Model.SelectedSpacesSummary</span>
            </button>
            <div class="dropdown-menu p-3 dashboard-space-menu">
                <fieldset class="mb-0">
                    <legend class="visually-hidden">Filter chores by space</legend>
                    <div class="dashboard-space-options">
                        @foreach (var space in Model.Spaces)
                        {
                            var checkboxId = $"space-{space.HouseholdId}";
                            <div class="form-check">
                                <input id="@checkboxId"
                                       class="form-check-input"
                                       type="checkbox"
                                       name="householdIds"
                                       value="@space.HouseholdId"
                                       checked="@(Model.EffectiveHouseholdIds.Contains(space.HouseholdId) ? "checked" : null)" />
                                <label class="form-check-label" for="@checkboxId">@space.Household.Name</label>
                            </div>
                        }
                    </div>
                </fieldset>
                <div class="dashboard-space-actions mt-3">
                    <a class="btn btn-sm btn-outline-secondary" href="@Model.BuildDashboardPath(Model.ActiveLabelId)">All spaces</a>
                    <button type="submit" class="btn btn-sm btn-primary">Apply</button>
                </div>
            </div>
        </div>
    </form>
}

@if (Model.AllLabels.Any())
{
    <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
          <a href="@Model.BuildDashboardPath()"
              class="badge filter-chip @(Model.ActiveLabelId == null ? "filter-chip-active" : string.Empty)">All</a>
        @foreach (var label in Model.AllLabels)
        {
            var isActive = Model.ActiveLabelId == label.Id;
            var textColor = label.GetAccessibleTextColor();
                <a href="@Model.BuildDashboardPath(label.Id)"
               class="badge filter-chip"
               style="background-color:@label.Color; border-color:@label.Color; opacity:@(isActive ? "1" : "0.75"); color:@textColor;">
                @label.Name
            </a>
        }
    </div>
}

@if (!Model.ChoreStatuses.Any())
{
    <p class="text-muted">No chores yet. <a asp-page="/Chores/Index">Add some chores</a> to get started.</p>
}
else
{
    <ul class="chore-list">
        @foreach (var cs in Model.ChoreStatuses)
        {
            <li>
                <a class="chore-row" href="/Chores/Complete?id=@cs.Chore.Id">
                    <span class="chore-name">
                        @cs.Chore.Name
                        @if (Model.ShowHouseholdNames)
                        {
                            <span class="text-muted small d-block">@cs.Chore.Household.Name</span>
                        }
                    </span>
                    <span class="chore-labels">
                        @foreach (var label in cs.Chore.Labels)
                        {
                            <span class="label-pill" style="background-color:@label.Color; color:@label.GetAccessibleTextColor();">@label.Name</span>
                        }
                    </span>
                    @{
                        var badgeClass = ScheduleAdherenceService.ToBadgeClass(cs.Chore.Schedule, cs.Adherence);
                        var badgeText = ScheduleAdherenceService.ToDisplayText(cs.Chore.Schedule, cs.Adherence);
                    }
                    <span class="badge @badgeClass">@badgeText</span>
                </a>
            </li>
        }
    </ul>
}
