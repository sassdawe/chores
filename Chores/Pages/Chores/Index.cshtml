@page
@model IndexModel
@{
    ViewData["Title"] = "Manage Chores";
}

<style>
    .filter-chip { text-decoration: none; border: 1px solid var(--bs-border-color); }
    .filter-chip-active { background-color: var(--bs-primary) !important; border-color: var(--bs-primary) !important; color: #fff !important; }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Manage Chores</h2>
    <a href="@Model.BuildCreatePath()" class="btn btn-primary">+ Add Chore</a>
</div>

@if (Model.AllLabels.Any())
{
    <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
        <a href="@Model.BuildManageChoresPath()"
           class="badge filter-chip @(Model.ActiveLabelId == null ? "filter-chip-active" : string.Empty)">All</a>
        @foreach (var label in Model.AllLabels)
        {
            var isActive = Model.ActiveLabelId == label.Id;
            var textColor = label.GetAccessibleTextColor();
            <a href="@Model.BuildManageChoresPath(label.Id)"
               class="badge filter-chip"
               style="background-color:@label.Color; border-color:@label.Color; opacity:@(isActive ? "1" : "0.75"); color:@textColor;">
                @label.Name
            </a>
        }
    </div>
}

<div class="row row-cols-2 row-cols-lg-4 g-2 mb-3">
    <div class="col">
        <div class="border rounded-3 p-3 h-100">
            <div class="text-muted small text-uppercase">Registered</div>
            <div class="fs-4 fw-semibold">@Model.TotalChoreCount</div>
        </div>
    </div>
    <div class="col">
        <div class="border rounded-3 p-3 h-100">
            <div class="text-muted small text-uppercase">On time</div>
            <div class="fs-4 fw-semibold text-success">@Model.OnTimeChoreCount</div>
        </div>
    </div>
    <div class="col">
        <div class="border rounded-3 p-3 h-100">
            <div class="text-muted small text-uppercase">Never done</div>
            <div class="fs-4 fw-semibold text-secondary">@Model.NeverDoneChoreCount</div>
        </div>
    </div>
    <div class="col">
        <div class="border rounded-3 p-3 h-100">
            <div class="text-muted small text-uppercase">Missed target</div>
            <div class="fs-4 fw-semibold text-danger">@Model.MissedTargetChoreCount</div>
        </div>
    </div>
</div>

@if (!Model.Chores.Any())
{
    <p class="text-muted">No chores yet. Add one to get started.</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Space</th>
                <th>Schedule</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var chore in Model.Chores)
            {
                <tr>
                    <td>@chore.Name</td>
                    <td>@chore.Household.Name</td>
                    <td>@chore.Schedule.ToFriendlyLabel()</td>
                    <td>
                        <a href="@Model.BuildHistoryPath(chore.Id)" class="btn btn-sm btn-outline-secondary">History</a>
                        <a href="@Model.BuildEditPath(chore.Id)" class="btn btn-sm btn-outline-secondary">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
