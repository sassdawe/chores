@page
@model CreateModel
@using System.Text.Json
@{
    ViewData["Title"] = "Add Chore";
    var labelsJson = JsonSerializer.Serialize(Model.AllAvailableLabels.Select(label => new
    {
        id = label.Id,
        householdId = label.HouseholdId,
        name = label.Name,
        color = label.Color,
        textColor = label.GetAccessibleTextColor(),
        isSelected = Model.SelectedLabelIds.Contains(label.Id)
    }));
}

<div style="max-width:480px;">
    <h2 class="mb-3">Add Chore</h2>

    <form method="post">
        <div class="mb-3">
            <label for="HouseholdId" class="form-label">Space</label>
            <select id="HouseholdId" name="HouseholdId" class="form-select">
                @foreach (var space in Model.Spaces)
                {
                    <option value="@space.HouseholdId" selected="@(space.HouseholdId == Model.HouseholdId ? "selected" : null)">
                        @space.Household.Name
                    </option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label for="Name" class="form-label">Chore name</label>
            <input id="Name" name="Name" class="form-control" value="@Model.Name" required />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label for="Schedule" class="form-label">Schedule</label>
            <select id="Schedule" name="Schedule" class="form-select">
                @foreach (Schedule s in Enum.GetValues(typeof(Schedule)))
                {
                    <option value="@s" selected="@(s == Model.Schedule ? "selected" : null)">@s.ToFriendlyLabel()</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Labels</label>
            <div id="labelsContainer" class="d-flex flex-wrap gap-2">
                @foreach (var label in Model.AvailableLabels)
                {
                    <label class="d-flex align-items-center gap-1" style="cursor:pointer;">
                        <input type="checkbox" name="SelectedLabelIds" value="@label.Id"
                               checked="@(Model.SelectedLabelIds.Contains(label.Id) ? "checked" : null)" />
                        <span class="badge" style="background-color:@label.Color; color:@label.GetAccessibleTextColor();">@label.Name</span>
                    </label>
                }
            </div>
            <p id="noLabelsMessage" class="text-muted small @(Model.AvailableLabels.Any() ? "d-none" : null)">
                No labels yet. <a id="createLabelLink" asp-page="/Labels/Create" asp-route-householdId="@Model.HouseholdId">Create one</a>
            </p>
        </div>
        <button type="submit" class="btn btn-primary me-2">Save</button>
        <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>

<script id="availableLabelsData" type="application/json">@Html.Raw(labelsJson)</script>

@section Scripts {
    <script>
        (function () {
            const householdSelect = document.getElementById('HouseholdId');
            const labelsContainer = document.getElementById('labelsContainer');
            const noLabelsMessage = document.getElementById('noLabelsMessage');
            const createLabelLink = document.getElementById('createLabelLink');
            const labelsJson = document.getElementById('availableLabelsData');
            const createLabelBaseUrl = '@Url.Page("/Labels/Create")';

            if (!householdSelect || !labelsContainer || !noLabelsMessage || !createLabelLink || !labelsJson) {
                return;
            }

            const allLabels = JSON.parse(labelsJson.textContent || '[]');
            const selectedLabelIds = new Set(
                allLabels
                    .filter(label => label.isSelected)
                    .map(label => String(label.id))
            );

            function syncSelectedLabels() {
                labelsContainer.querySelectorAll('input[name="SelectedLabelIds"]').forEach((checkbox) => {
                    if (checkbox.checked) {
                        selectedLabelIds.add(checkbox.value);
                    } else {
                        selectedLabelIds.delete(checkbox.value);
                    }
                });
            }

            function createLabelOption(label) {
                const wrapper = document.createElement('label');
                wrapper.className = 'd-flex align-items-center gap-1';
                wrapper.style.cursor = 'pointer';

                const checkbox = document.createElement('input');
                checkbox.type = 'checkbox';
                checkbox.name = 'SelectedLabelIds';
                checkbox.value = String(label.id);
                checkbox.checked = selectedLabelIds.has(String(label.id));

                const badge = document.createElement('span');
                badge.className = 'badge';
                badge.style.backgroundColor = label.color;
                badge.style.color = label.textColor;
                badge.textContent = label.name;

                wrapper.appendChild(checkbox);
                wrapper.appendChild(badge);
                return wrapper;
            }

            function renderLabels() {
                syncSelectedLabels();

                const householdId = Number(householdSelect.value);
                const labelsForHousehold = allLabels.filter(label => label.householdId === householdId);

                labelsContainer.replaceChildren();
                labelsForHousehold.forEach((label) => {
                    labelsContainer.appendChild(createLabelOption(label));
                });

                noLabelsMessage.classList.toggle('d-none', labelsForHousehold.length > 0);
                createLabelLink.href = `${createLabelBaseUrl}?householdId=${encodeURIComponent(householdSelect.value)}`;
            }

            labelsContainer.addEventListener('change', syncSelectedLabels);
            householdSelect.addEventListener('change', renderLabels);
            renderLabels();
        })();
    </script>
}
