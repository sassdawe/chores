@page
@model IndexModel
@{
    ViewData["Title"] = "My Profile";
}

<h2>My Profile</h2>
<p>Signed in as: <strong>@Model.CurrentUser.LoginName</strong></p>
@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-info py-2" style="max-width:680px">@Model.StatusMessage</div>
}

<div class="mb-4">
    <a asp-page-handler="Export" class="btn btn-outline-primary">Export household data (JSON)</a>
</div>

<h4>Passkeys</h4>
<table class="table table-sm" style="max-width:680px">
    <thead>
        <tr>
            <th>Name</th>
            <th>Registered</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var pk in Model.Passkeys)
        {
            <tr>
                <td>
                    <form method="post" asp-page-handler="Rename" asp-route-credentialId="@pk.Id"
                          class="d-flex gap-1 align-items-center">
                        @Html.AntiForgeryToken()
                        <input type="text" name="nickname" class="form-control form-control-sm"
                               style="max-width:200px"
                               value="@(pk.Nickname ?? string.Empty)"
                               placeholder="@pk.RegDate.ToLocalTime().ToString("MMM d, yyyy HH:mm")" />
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Save</button>
                    </form>
                </td>
                <td class="align-middle text-nowrap">@pk.RegDate.ToLocalTime().ToString("MMM d, yyyy HH:mm")</td>
                <td class="align-middle">
                    @if (Model.Passkeys.Count == 1)
                    {
                        <button class="btn btn-sm btn-outline-danger" disabled
                                title="You must keep at least one passkey">Delete</button>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="Delete" asp-route-credentialId="@pk.Id" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<button id="addPasskeyBtn" class="btn btn-primary mt-2">+ Add passkey</button>
<p id="passkeyMessage" class="mt-2" style="display:none"></p>

@if (Model.PendingInvites.Any())
{
    <h4 class="mt-4">Pending household invites</h4>
    <table class="table table-sm" style="max-width:680px">
        <thead>
            <tr>
                <th>Household</th>
                <th>Invited by</th>
                <th>Sent</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var invite in Model.PendingInvites)
            {
                <tr>
                    <td>@invite.Household.Name</td>
                    <td>@invite.InvitedByUser.LoginName</td>
                    <td class="text-nowrap">@invite.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy HH:mm")</td>
                    <td>
                        @if (Model.CurrentUser.IsHouseholdOwner)
                        {
                            <button class="btn btn-sm btn-outline-secondary" disabled
                                    title="Transfer household ownership before joining another household">
                                Accept
                            </button>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="AcceptInvite" asp-route-inviteId="@invite.Id" style="display:inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-primary">Accept</button>
                            </form>
                        }
                        <form method="post" asp-page-handler="DeclineInvite" asp-route-inviteId="@invite.Id" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-secondary">Decline</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
<script>
    function base64urlToArrayBuffer(base64url) {
        const base64 = base64url.replace(/-/g, '+').replace(/_/g, '/');
        const padded = base64.padEnd(base64.length + (4 - base64.length % 4) % 4, '=');
        const binary = atob(padded);
        const buf = new ArrayBuffer(binary.length);
        const view = new Uint8Array(buf);
        for (let i = 0; i < binary.length; i++) view[i] = binary.charCodeAt(i);
        return buf;
    }

    function arrayBufferToBase64url(buffer) {
        const bytes = new Uint8Array(buffer);
        let str = '';
        for (const b of bytes) str += String.fromCharCode(b);
        return btoa(str).replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
    }

    document.getElementById('addPasskeyBtn').addEventListener('click', async () => {
        const msg = document.getElementById('passkeyMessage');
        msg.style.display = 'none';

        try {
            // Step 1: get attestation options (server reads username from auth cookie)
            const optRes = await fetch('/api/profile/passkey/options', { method: 'POST' });
            if (!optRes.ok) throw new Error('Failed to get attestation options.');
            const options = await optRes.json();

            // Convert base64url fields to ArrayBuffer
            options.challenge = base64urlToArrayBuffer(options.challenge);
            options.user.id = base64urlToArrayBuffer(options.user.id);
            if (options.excludeCredentials) {
                options.excludeCredentials = options.excludeCredentials.map(c => ({
                    ...c,
                    id: base64urlToArrayBuffer(c.id)
                }));
            }

            // Step 2: create credential
            const credential = await navigator.credentials.create({ publicKey: options });

            // Step 3: encode response
            const attestationResult = {
                id: credential.id,
                rawId: arrayBufferToBase64url(credential.rawId),
                type: credential.type,
                clientExtensionResults: credential.getClientExtensionResults(),
                response: {
                    attestationObject: arrayBufferToBase64url(credential.response.attestationObject),
                    clientDataJSON: arrayBufferToBase64url(credential.response.clientDataJSON)
                }
            };

            // Step 4: send to server
            const resResult = await fetch('/api/profile/passkey/result', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(attestationResult)
            });
            if (!resResult.ok) throw new Error('Failed to register passkey on server.');
            const data = await resResult.json();
            if (data.status === 'ok') {
                window.location.reload();
            } else {
                throw new Error('Unexpected server response.');
            }
        } catch (err) {
            msg.textContent = 'Error: ' + err.message;
            msg.style.display = 'block';
        }
    });
</script>
}
