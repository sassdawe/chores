@page
@model LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm p-4">
            <h1 class="h4 mb-3">Sign in</h1>
            <form id="loginForm" novalidate>
                <label for="loginName" class="form-label">Login name</label>
                <input type="text" id="loginName" name="username" placeholder="Login name" autocomplete="username webauthn" autocapitalize="none" class="form-control mb-2" />
                <div class="form-check mb-3">
                    <input type="checkbox" id="rememberLoginName" class="form-check-input" />
                    <label for="rememberLoginName" class="form-check-label">Remember me on this device</label>
                </div>
                <button id="loginBtn" type="submit" class="btn btn-primary">Sign in</button>
            </form>
            <p class="text-muted mt-2 small">
                We use your login name only to start passkey sign-in. No password or email is collected here.
                <a href="/Privacy">Read the privacy policy</a>.
            </p>
            <p id="message" class="mt-2" style="display:none"></p>
            <p class="mt-2 mb-0">Don't have an account? <a href="/Auth/Register">Create one</a></p>
        </div>
    </div>
</div>

<script>
    const rememberedLoginNameKey = 'chores.lastLoginName';

    function base64urlToArrayBuffer(base64url) {
        const base64 = base64url.replace(/-/g, '+').replace(/_/g, '/');
        const padded = base64.padEnd(base64.length + (4 - base64.length % 4) % 4, '=');
        const binary = atob(padded);
        const buf = new ArrayBuffer(binary.length);
        const view = new Uint8Array(buf);
        for (let i = 0; i < binary.length; i++) view[i] = binary.charCodeAt(i);
        return buf;
    }

    function arrayBufferToBase64url(buffer) {
        const bytes = new Uint8Array(buffer);
        let str = '';
        for (const b of bytes) str += String.fromCharCode(b);
        return btoa(str).replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
    }

    const loginForm = document.getElementById('loginForm');
    const loginNameInput = document.getElementById('loginName');
    const rememberLoginNameCheckbox = document.getElementById('rememberLoginName');

    let rememberedLoginName = null;
    try {
        rememberedLoginName = localStorage.getItem(rememberedLoginNameKey);
    } catch {
    }
    if (rememberedLoginName) {
        loginNameInput.value = rememberedLoginName;
        rememberLoginNameCheckbox.checked = true;
    }

    loginForm.addEventListener('submit', async event => {
        event.preventDefault();

        const msg = document.getElementById('message');
        msg.style.display = 'none';

        const username = loginNameInput.value.trim();
        if (!username) {
            msg.textContent = 'Please enter your login name.';
            msg.style.display = 'block';
            return;
        }

        try {
            // Step 1: get assertion options
            const optRes = await fetch('/api/auth/assertion/options', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username })
            });
            if (!optRes.ok) throw new Error('Failed to get assertion options.');
            const options = await optRes.json();

            // Convert base64url fields to ArrayBuffer
            options.challenge = base64urlToArrayBuffer(options.challenge);
            if (options.allowCredentials) {
                options.allowCredentials = options.allowCredentials.map(c => ({
                    ...c,
                    id: base64urlToArrayBuffer(c.id)
                }));
            }

            // Step 2: get assertion
            const assertion = await navigator.credentials.get({ publicKey: options });

            // Step 3: encode response
            const assertionResult = {
                id: assertion.id,
                rawId: arrayBufferToBase64url(assertion.rawId),
                type: assertion.type,
                clientExtensionResults: assertion.getClientExtensionResults(),
                response: {
                    authenticatorData: arrayBufferToBase64url(assertion.response.authenticatorData),
                    clientDataJSON: arrayBufferToBase64url(assertion.response.clientDataJSON),
                    signature: arrayBufferToBase64url(assertion.response.signature),
                    userHandle: assertion.response.userHandle
                        ? arrayBufferToBase64url(assertion.response.userHandle)
                        : null
                }
            };

            // Step 4: send to server
            const resResult = await fetch('/api/auth/assertion/result', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(assertionResult)
            });
            if (!resResult.ok) throw new Error('Authentication failed on server.');
            const data = await resResult.json();
            if (data.status === 'ok') {
                try {
                    if (rememberLoginNameCheckbox.checked) {
                        localStorage.setItem(rememberedLoginNameKey, username);
                    } else {
                        localStorage.removeItem(rememberedLoginNameKey);
                    }
                } catch {
                    // Ignore storage failures and continue sign-in without persistence.
                }

                window.location.href = '/';
            } else {
                throw new Error('Unexpected server response.');
            }
        } catch (err) {
            msg.textContent = 'Sign in failed: ' + err.message;
            msg.style.display = 'block';
        }
    });
</script>
